{
  "name": "waddle-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "sync:openapi": "uv run --project ../../.. python ../waddle_server/tools/dump_openapi.py > src/api/openapi.json",
    "generate:api": "openapi-typescript src/api/openapi.json -o src/api/schema.gen.ts"
  },
  "dependencies": {
    "@sx/api-client": "workspace:*",
    "@sx/ui": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "uplot": "^1.6.31"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.20",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
